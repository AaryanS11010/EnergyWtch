# EnergyWatch — environment variables
# Copy this file to .env and fill in the values.

# Server port (default 4000)
PORT=4000

# JWT signing secret — change this to any long random string
JWT_SECRET=change-me-to-something-random-and-long

# Gmail SMTP — only needed for real email verification
# If left blank, the 6-digit code is printed to the server console instead.
# To get an App Password:
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Create an App Password:     https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
